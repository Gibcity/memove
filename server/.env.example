PORT=3001 # Port to run the server on (default: 3001)
# HOST=0.0.0.0 # Bind address for the HTTP server. Only set this when running memove from sources or via the Proxmox community script — never in Docker (the container handles binding).
NODE_ENV=development # development = development mode; production = production mode
APP_VERSION= # Override the application version. Defaults to the value in package.json when unset. Used by migrations and system notices.
# ENCRYPTION_KEY=<random-256-bit-hex>  # Separate key for encrypting stored secrets (API keys, MFA, SMTP, OIDC, etc.)
# Auto-generated and persisted to ./data/.encryption_key if not set.
# Upgrade from a version that used JWT_SECRET for encryption: set to your old JWT_SECRET value so
# existing encrypted data remains readable, then re-save credentials via the admin panel.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TZ=UTC # Timezone for logs, reminders and scheduled tasks (e.g. Europe/Berlin)
# DEFAULT_LANGUAGE=en # Default language on the login page for users with no saved preference (default: en)
# SESSION_DURATION=30d # How long users stay logged in — sets the memove_session JWT exp + cookie maxAge. Accepts 1h, 12h, 7d, 30d, 90d. Default: 24h
# SESSION_DURATION_REMEMBER=30d # Session length when "Remember me" is ticked at login — longer-lived JWT + persistent cookie that survives browser restarts. Same format as SESSION_DURATION. Default: 30d
# Supported values: de, en, es, fr, hu, nl, br, cs, pl, ru, zh, zh-TW, it, ar
# Note: browser/OS language is detected automatically first; this is the fallback when no match is found.
LOG_LEVEL=info # info = concise user actions; debug = verbose admin-level details

# ─── Database ─────────────────────────────────────────────────────────────────
# MEMOVE_DB_FILE= # Override the SQLite database file path. Defaults to ./data/travel.db. Used by the Playwright E2E harness to point at an isolated DB.
# MEMOVE_PLACE_PHOTO_DIR= # Directory for cached Google Place photos. Defaults to ./uploads/photos/google relative to the server build.

# ─── HTTP / Networking ────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://memove.example.com # Comma-separated origins for CORS and email links
FORCE_HTTPS=false # Optional. When true: HTTPS redirect + HSTS + CSP upgrade-insecure-requests + secure cookies. Only behind a TLS proxy.
# HSTS_INCLUDE_SUBDOMAINS=false # When true: adds includeSubDomains to the HSTS header. Only effective when HSTS is active (FORCE_HTTPS=true or NODE_ENV=production). Leave false if you run other services on sibling subdomains over plain HTTP.
COOKIE_SECURE=true # Auto-derived (true when NODE_ENV=production or FORCE_HTTPS=true). Set false to force cookies over plain HTTP.
TRUST_PROXY=1 # Trusted proxy hops (parseInt or 1). Active in production by default; off in dev unless set. Needed for FORCE_HTTPS.
ALLOW_INTERNAL_NETWORK=false # Allow outbound requests to private/RFC1918 IPs (e.g. Immich hosted on your LAN). Loopback and link-local addresses are always blocked.

APP_URL=https://memove.example.com # Base URL of this instance — required when OIDC is enabled; must match the redirect URI registered with your IdP

# ─── Auth: OIDC / SSO ─────────────────────────────────────────────────────────
OIDC_ISSUER=https://auth.example.com # OpenID Connect provider URL
OIDC_CLIENT_ID=memove # OpenID Connect client ID
OIDC_CLIENT_SECRET=supersecret # OpenID Connect client secret
OIDC_DISPLAY_NAME=SSO # Label shown on the SSO login button
OIDC_ONLY=true # Disable local password auth entirely (SSO only). Equivalent to setting password_login=false and password_registration=false in Admin > Settings.
OIDC_ADMIN_CLAIM=groups # OIDC claim used to identify admin users
OIDC_ADMIN_VALUE=app-memove-admins # Value of the OIDC claim that grants admin role
OIDC_DISCOVERY_URL= # Override the auto-constructed OIDC discovery endpoint. Useful for providers (e.g. Authentik) that expose it at a non-standard path. Example: https://auth.example.com/application/o/memove/.well-known/openid-configuration
OIDC_SCOPE=openid email profile # Fully overrides the default. Add extra scopes as needed (e.g. add groups if using OIDC_ADMIN_CLAIM)

# ─── Auth: WebAuthn / Passkeys ────────────────────────────────────────────────
# WEBAUTHN_RP_ID=memove.example.com # Explicit Relying Party ID for WebAuthn. Defaults to the host of APP_URL when unset.
# WEBAUTHN_ORIGINS=https://memove.example.com # Comma-separated exact origins (scheme + host + port) allowed for WebAuthn ceremonies. Defaults to the origin of APP_URL.

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
# SMTP_HOST=smtp.example.com # SMTP server hostname. Falls back to the smtp_host admin setting. Email is disabled when neither is set.
# SMTP_PORT=587 # SMTP server port. 465 = implicit TLS, 587 = STARTTLS (default), 25 = plain. Falls back to smtp_port admin setting.
# SMTP_USER= # SMTP authentication username. Optional when the server allows anonymous relay.
# SMTP_PASS= # SMTP authentication password. Falls back to the encrypted smtp_pass admin setting.
# SMTP_FROM="memove <noreply@example.com>" # Default From: header. Falls back to the smtp_from admin setting.
# SMTP_SKIP_TLS_VERIFY=false # Skip TLS certificate verification when connecting to the SMTP server. Set true only for self-signed dev/test servers.

# ─── LLM (relocation concierge chat) ──────────────────────────────────────────
# MINIMAX_API_KEY=your-key-here # API key for the MiniMax-M3 chat model. When unset, LLM features fall back to hardcoded responses — the server still boots.
# MINIMAX_BASE_URL=https://api.minimax.io/v1 # Base URL of the OpenAI-compatible endpoint. Override for proxies or alternative deployments.
# MINIMAX_MODEL=MiniMax-M3 # Model name passed to the chat completions endpoint.

# ─── Demo mode ────────────────────────────────────────────────────────────────
DEMO_MODE=false # Demo mode - resets data hourly
# DEMO_ADMIN_USER=admin # Username of the demo admin account created on first boot when DEMO_MODE=true (default: admin)
# DEMO_ADMIN_EMAIL=admin@memove.app # Email of the demo admin account (default: admin@memove.app)
# DEMO_ADMIN_PASS=admin12345 # Password of the demo admin account (default: admin12345)

# ─── Booking import / KItinerary ──────────────────────────────────────────────
# KITINERARY_EXTRACTOR_PATH= # Absolute path to the kitinerary-extractor binary. Auto-discovered on Debian/Ubuntu when unset.

# ─── Scheduler ────────────────────────────────────────────────────────────────
# IDEMPOTENCY_TTL_SECONDS=2592000 # How long idempotency keys are retained before purge (default: 2592000 = 30 days).

# BACKUP_UPLOAD_LIMIT_MB=500 # Max size (MB) of a backup archive you can upload when restoring. Raise it if your backup exceeds 500 MB. If you sit behind a reverse proxy, raise its upload limit too (e.g. nginx client_max_body_size).

# MCP_RATE_LIMIT=300 # Max MCP API requests per user per minute (default: 300)
# MCP_MAX_SESSION_PER_USER=20 # Max concurrent MCP sessions per user (default: 20)

# ─── Initial admin account ────────────────────────────────────────────────────
# Only used on first boot when no users exist yet.
# If both are set the admin account is created with these credentials.
# If either is omitted a random password is generated and printed to the server log.
# ADMIN_EMAIL=admin@memove.local
# ADMIN_PASSWORD=changeme